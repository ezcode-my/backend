{
  "settings": {
    "index.max_ngram_diff": 15,
    "analysis": {
      "tokenizer": {
        "edge_tokenizer": {
          "type": "edge_ngram",
          "min_gram": 2,
          "max_gram": 10,
          "token_chars": [
            "letter",
            "digit",
            "symbol",
            "punctuation"
          ]
        }
      },
      "filter": {
        "lowercase_filter": {
          "type": "lowercase"
        },
        "uppercase_filter": {
          "type": "uppercase"
        }
      },
      "analyzer": {
        "uppercase_analyzer": {
          "type": "custom",
          "tokenizer": "edge_tokenizer",
          "filter": [
            "uppercase_filter"
          ]
        },
        "lowercase_analyzer": {
          "type": "custom",
          "tokenizer": "edge_tokenizer",
          "filter": [
            "lowercase_filter"
          ]
        },
        "lowercase_standard": {
          "tokenizer": "uax_url_email",
          "filter": ["lowercase"]
        },
        "uppercase_standard": {
          "tokenizer": "uax_url_email",
          "filter": ["uppercase"]
        }
      },
      "normalizer": {
        "lowercase_normalizer": {
          "type": "custom",
          "filter": [
            "lowercase_filter"
          ]
        },
        "uppercase_normalizer": {
          "type": "custom",
          "filter": [
            "uppercase_filter"
          ]
        }
      }
    }
  },
  "mappings": {
    "properties": {
      "title": {
        "type": "text",
        "analyzer": "lowercase_analyzer",
        "search_analyzer": "lowercase_standard",
        "fields": {
          "keyword": {
            "type": "keyword",
            "normalizer": "lowercase_normalizer"
          }
        }
      },
      "description": {
        "type": "text",
        "analyzer": "standard"
      },
      "category": {
        "type": "text",
        "analyzer": "uppercase_analyzer",
        "search_analyzer": "uppercase_standard",
        "fields": {
          "keyword": {
            "type": "keyword",
            "normalizer": "uppercase_normalizer"
          }
        }
      },
      "difficulty": {
        "type": "text",
        "analyzer": "uppercase_analyzer",
        "search_analyzer": "uppercase_standard",
        "fields": {
          "keyword": {
            "type": "keyword",
            "normalizer": "uppercase_normalizer"
          }
        }
      },
      "reference": {
        "type": "text",
        "analyzer": "uppercase_analyzer",
        "search_analyzer": "uppercase_standard",
        "fields": {
          "keyword": {
            "type": "keyword",
            "normalizer": "uppercase_normalizer"
          }
        }
      },
      "isDeleted": {
        "type": "boolean"
      },
      "score": {
        "type": "keyword"
      },
      "id": {
        "type": "keyword"
      }
    }
  }
}
